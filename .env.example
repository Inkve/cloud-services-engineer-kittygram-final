# =====================
# PostgreSQL
# =====================
POSTGRES_DB=<kittygram_database>
POSTGRES_USER=<kittygram_database_user>
POSTGRES_PASSWORD=<kittygram__database_password>

# =====================
# Database connection
# =====================
DB_HOST=localhost
DB_PORT=5432

# =====================
# Django settings
# =====================
DJANGO_SECRET_KEY=<django-insecure-change-me>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1